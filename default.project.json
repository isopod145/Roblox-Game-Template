{
  "name": "Roblox Game Template",
  "tree": {
    "$className": "DataModel",

    "Players": {
      "$properties": {
        "CharacterAutoLoads": false
      }
    },

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared",
        "Packages": {
          "$path": "roblox_packages"
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        },

        "$path": "roblox/StarterPlayerScripts"
      }
    }
  }
}